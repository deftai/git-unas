{
  "name": "git-unas",
  "version": "1.3.0",
  "description": "Node.js/TypeScript web admin page for Ubiquiti UNAS — git clone, tar, and encryption",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "build:binary": "pkg dist/server.js --targets node22-linux-arm64 --output dist/git-unas-arm64 --config pkg.config.json --no-bytecode",
    "build:bundle": "ncc build dist/server.js -o dist/bundle -m",
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node src/server.ts",
    "fmt": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "fmt:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "clean": "rm -rf dist/"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "pkg": {
    "assets": [
      "public/**/*",
      "node_modules/**/*.js",
      "node_modules/**/*.json"
    ],
    "scripts": [
      "dist/**/*.js"
    ]
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "node-cron": "^4.2.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vercel/ncc": "^0.44.1",
    "@yao-pkg/pkg": "^6.20.0",
    "eslint": "^10.4.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
